@model WarsztatTuningowy.Models.Domain.ServiceTask

@{
    ViewData["Title"] = "Edycja zadania";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Zadania serwisowe</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">@Model.Name</a></li>
        <li class="breadcrumb-item active">Edycja</li>
    </ol>
</nav>

<div class="page-header mb-4">
    <h1>Edycja zadania</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Dane zadania</div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="OrderId" />

                    <div class="alert alert-info mb-4">
                        Zadanie jest przypisane do <strong>Zlecenia #@Model.OrderId</strong>.
                    </div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="AssignedEmployeeId" class="form-label fw-semibold"></label>
                            <select asp-for="AssignedEmployeeId" class="form-select" asp-items="ViewBag.AssignedEmployeeId">
                                <option value="">-- Nieprzypisany --</option>
                            </select>
                            <span asp-validation-for="AssignedEmployeeId" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label fw-semibold"></label>
                            <textarea asp-for="Notes" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                            <div class="form-text">Notatki techniczne i uwagi zgłaszane w trakcie realizacji.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-4 mt-4 border-top">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}