@model WarsztatTuningowy.Models.Domain.ServiceTask
@{
    ViewData["Title"] = "Szczegóły zadania";
    
    bool notStarted = Model.StartTime == null;
    bool inProgress = Model.StartTime != null && Model.EndTime == null;
    bool finished = Model.EndTime != null;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Orders" asp-action="Index">Zlecenia</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Orders" asp-action="Details"
               asp-route-id="@Model.OrderId">
                Zlecenie #@Model.OrderId
            </a>
        </li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="mb-1">@Model.Name</h1>
        <small class="text-muted">
            Zlecenie #@Model.OrderId —
            @Model.Order?.Vehicle?.Brand @Model.Order?.Vehicle?.Model
        </small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-outline-primary">Edytuj</a>
        <a asp-controller="Orders" asp-action="Details"
           asp-route-id="@Model.OrderId"
           class="btn btn-outline-secondary">Wróć do zlecenia</a>
    </div>
</div>

@* Karta z informacjami o czasie *@
<div class="card mb-4">
    <div class="card-header fw-bold">Timer RBH</div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="text-muted small">Status</div>
                @if (notStarted)
                {
                    <span class="badge bg-secondary">Nie rozpoczęto</span>
                }
                else if (inProgress)
                {
                    <span class="badge bg-warning text-dark">W trakcie</span>
                }
                else
                {
                    <span class="badge bg-success">Zakończono</span>
                }
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Start</div>
                <strong>
                    @(Model.StartTime?.ToString("dd.MM.yyyy HH:mm") ?? "—")
                </strong>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Koniec</div>
                <strong>
                    @(Model.EndTime?.ToString("dd.MM.yyyy HH:mm") ?? "—")
                </strong>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Czas pracy</div>
                <strong class="fs-5">@Model.TotalTime</strong>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            @if (notStarted)
            {
                <form asp-action="Start" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success btn-lg">
                        ▶ START
                    </button>
                </form>
            }

            @if (inProgress)
            {
                <form asp-action="Stop" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger btn-lg">
                        ⬛ STOP
                    </button>
                </form>

                <form asp-action="Pause" method="post"
                      class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="number" name="pauseMinutes"
                           class="form-control" style="width:100px"
                           min="1" max="999" placeholder="min"
                           required />
                    <button type="submit" class="btn btn-warning btn-lg">
                        ⏸ PAUZA
                    </button>
                </form>
            }
        </div>

        @if (Model.PausedMinutes > 0)
        {
            <div class="text-muted mt-2 small">
                Łączny czas przerw: @Model.PausedMinutes min
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-bold">Notatki techniczne</div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <pre style="white-space:pre-line; font-family:inherit">
                @Model.Notes
            </pre>
        }
        else
        {
            <p class="text-muted">Brak notatek</p>
        }

        <form asp-action="AddNotes" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="mb-2">
                <textarea name="notes" class="form-control" rows="3"
                          placeholder="Dodaj notatkę techniczną..."
                          required></textarea>
            </div>
            <button type="submit" class="btn btn-outline-primary">
                Dodaj notatkę
            </button>
        </form>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Przypisany pracownik</dt>
    <dd class="col-sm-9">
        @(Model.AssignedEmployee?.FullName ?? "Nieprzypisany")
    </dd>
</dl>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}