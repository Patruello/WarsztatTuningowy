<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WarsztatTuningowy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/WarsztatTuningowy.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    ⚙️ Warsztat <span>Tuningowy</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-4 gap-1 me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                🏠 Pulpit
                            </a>
                        </li>

                        @if (User.IsInRole("Owner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Clients"
                                   asp-action="Index">
                                    👥 Klienci
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Vehicles"
                                   asp-action="Index">
                                    🚗 Pojazdy
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Orders"
                                   asp-action="Index">
                                    🔧 Zlecenia
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Parts"
                                   asp-action="Index">
                                    📦 Magazyn
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Workstations"
                                   asp-action="Index">
                                    🏭 Stanowiska
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" asp-controller="Employees"
                                   asp-action="Index">
                                    🧑‍🔧 Pracownicy
                                </a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WarsztatTuningowy - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
