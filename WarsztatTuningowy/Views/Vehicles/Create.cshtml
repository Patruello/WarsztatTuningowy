@model WarsztatTuningowy.Models.Domain.Vehicle
@{
    ViewData["Title"] = "Nowy pojazd";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Pojazdy</a>
        </li>
        <li class="breadcrumb-item active">Nowy pojazd</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
        color:var(--gray-500);text-transform:uppercase;
        margin-bottom:.5rem">
        Nowy rekord
    </div>
    <h1>Dodaj pojazd</h1>
    <p class="page-subtitle">
        Wprowadź dane techniczne pojazdu i przypisz do klienta.
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-bold">Dane pojazdu</div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Brand" class="form-label">
                                Marka <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Brand" class="form-control" placeholder="np. BMW" />
                            <span asp-validation-for="Brand"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label">
                                Model <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Model" class="form-control"
                                   placeholder="np. 335i" />
                            <span asp-validation-for="Model"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Year" class="form-label">
                                Rok <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Year" class="form-control" placeholder="np. 2020" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="VIN" class="form-label">
                                Numer VIN <span class="text-danger">*</span>
                            </label>
                            <input asp-for="VIN" class="form-control"
                                   placeholder="17 znaków" maxlength="17" />
                            <div class="form-text">VIN musi mieć 17 znaków</div>
                            <span asp-validation-for="VIN" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EngineType" class="form-label">
                            Typ silnika <span class="text-danger">*</span>
                        </label>
                        <input asp-for="EngineType" class="form-control"
                               placeholder="np. 3.0 TwinPower Turbo 306KM" />
                        <span asp-validation-for="EngineType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ECUType" class="form-label">
                            Typ ECU <span class="text-danger">*</span>
                        </label>
                        <input asp-for="ECUType" class="form-control" placeholder="np. Bosch MSD80" />
                        <span asp-validation-for="ECUType" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ClientId" class="form-label">
                            Właściciel <span class="text-danger">*</span>
                        </label>
                        <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId">
                            <option value="">— wybierz klienta —</option>
                        </select>
                        <span asp-validation-for="ClientId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                        @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl as string))
                        {
                            <a href="@ViewBag.ReturnUrl"
                               class="btn btn-outline-secondary">Anuluj</a>
                        }
                        else
                        {
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">Anuluj</a>
                        }
                        <button type="submit" class="btn btn-primary">
                            ✓ Dodaj pojazd
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-bold">Podgląd</div>
            <div class="card-body">
                <div class="fw-semibold fs-5" id="previewTitle">
                    Marka Model
                </div>
                <div class="text-muted small mb-3" id="previewYear">Rok</div>
                <dl class="row small mb-0">
                    <dt class="col-5 text-muted">Silnik</dt>
                    <dd class="col-7" id="previewEngine">—</dd>
                    <dt class="col-5 text-muted">ECU</dt>
                    <dd class="col-7" id="previewEcu">—</dd>
                    <dt class="col-5 text-muted">VIN</dt>
                    <dd class="col-7">
                        <code id="previewVin">—</code>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function bind(inputId, previewId, fallback) {
            var el = document.querySelector('[name="' + inputId + '"]');
            if (!el) return;
            el.addEventListener('input', function() {
                document.getElementById(previewId).textContent =
                    this.value || fallback;
            });
        }
        bind('Brand',      'previewTitle',  'Marka');
        bind('Model',      'previewTitle',  'Model');
        bind('Year',       'previewYear',   'Rok');
        bind('EngineType', 'previewEngine', '—');
        bind('ECUType',    'previewEcu',    '—');
        bind('VIN',        'previewVin',    '—');

        ['Brand','Model'].forEach(function(name) {
            document.querySelector('[name="' + name + '"]')
                ?.addEventListener('input', function() {
                    var brand = document.querySelector('[name="Brand"]')?.value || 'Marka';
                    var model = document.querySelector('[name="Model"]')?.value || 'Model';
                    document.getElementById('previewTitle').textContent =
                        brand + ' ' + model;
                });
        });
    </script>
}