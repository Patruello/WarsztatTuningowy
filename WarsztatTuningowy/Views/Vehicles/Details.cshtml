@model WarsztatTuningowy.Models.Domain.Vehicle
@using WarsztatTuningowy.Extensions
@using WarsztatTuningowy.Models.Enums
@{
    ViewData["Title"] = "Szczegóły pojazdu";
    var allOrders = Model.Orders.OrderByDescending(o => o.CreatedAt).ToList();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Pojazdy</a>
        </li>
        <li class="breadcrumb-item active">
            @Model.Brand @Model.Model
        </li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">
            @Model.Brand @Model.Model
            <small class="text-muted fs-4">(@Model.Year)</small>
        </h1>
        <small class="text-muted">
            Właściciel:
            <a asp-controller="Clients" asp-action="Details"
                   asp-route-id="@Model.ClientId">
                @Model.Client.FullName
            </a>
        </small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-outline-primary">Edytuj</a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Wróć do listy
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">Dane techniczne</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">VIN</dt>
                    <dd class="col-sm-8"><code>@Model.VIN</code></dd>
                    <dt class="col-sm-4 text-muted">Silnik</dt>
                    <dd class="col-sm-8">@Model.EngineType</dd>
                    <dt class="col-sm-4 text-muted">Typ ECU</dt>
                    <dd class="col-sm-8">@Model.ECUType</dd>
                    <dt class="col-sm-4 text-muted">Specyfikacja</dt>
                    <dd class="col-sm-8">
                        <small class="text-muted">@Model.TuningSpec</small>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold">Statystyki</div>
            <div class="card-body d-flex gap-3">
                <div class="text-center flex-fill">
                    <div class="fs-1 fw-bold text-primary">
                        @allOrders.Count
                    </div>
                    <div class="text-muted small">Zlecenia łącznie</div>
                </div>
                <div class="text-center flex-fill">
                    <div class="fs-1 fw-bold text-success">
                        @allOrders.Count(o => o.Status == OrderStatus.Completed)
                    </div>
                    <div class="text-muted small">Zakończone</div>
                </div>
                <div class="text-center flex-fill">
                    <div class="fs-1 fw-bold text-warning">
                        @allOrders.Count(o => o.Status != OrderStatus.Completed)
                    </div>
                    <div class="text-muted small">W toku</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold">Historia zleceń</span>
        <a asp-controller="Orders" asp-action="Create"
           class="btn btn-sm btn-primary">+ Nowe zlecenie</a>
    </div>
    <div class="card-body p-0">
        @if (!allOrders.Any())
        {
            <p class="text-muted p-3 mb-0">Brak zleceń dla tego pojazdu</p>
        }
        else
        {
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th>Nr</th>
                        <th>Cel tuningu</th>
                        <th>Status</th>
                        <th>Zadania</th>
                        <th>Data</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in allOrders)
                    {
                        var badgeClass = order.Status switch
                        {
                            OrderStatus.Received => "bg-secondary",
                            OrderStatus.Diagnosis => "bg-info",
                            OrderStatus.InProgress => "bg-warning text-dark",
                            OrderStatus.QualityCheck => "bg-primary",
                            OrderStatus.Completed => "bg-success",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>
                                <small>
                                    @order.TuningGoal.GetDisplayName()
                                </small>
                            </td>
                            <td>
                                <span class="badge @badgeClass">
                                    @order.Status.GetDisplayName()
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">
                                    @order.ServiceTasks.Count zadań
                                </span>
                            </td>
                            <td>
                                <small>
                                    @order.CreatedAt.ToString("dd.MM.yyyy")
                                </small>
                            </td>
                            <td>
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                   class="btn-action" title="Szczegóły">👁</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>