@model IEnumerable<WarsztatTuningowy.Models.Domain.Invoice>
@{
    ViewData["Title"] = "Faktury";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Faktury</li>
    </ol>
</nav>

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Faktury</h1>
        <p class="page-subtitle">@Model.Count() faktur w systemie</p>
    </div>
    <a asp-action="ExportInvoicesCsv"
       class="btn btn-outline-success">
        ⬇ Eksport CSV
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-muted text-center p-4">
            Brak faktur — wygeneruj pierwszą fakturę ze zlecenia.
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-modern w-100">
                <thead>
                    <tr>
                        <th>Numer</th>
                        <th>Data</th>
                        <th>Klient</th>
                        <th>Pojazd</th>
                        <th>Netto</th>
                        <th>VAT</th>
                        <th>Brutto</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model)
                    {
                        <tr>
                            <td>
                                <strong>@invoice.Number</strong>
                            </td>
                            <td>
                                @invoice.IssuedAt.ToString("dd.MM.yyyy")
                            </td>
                            <td>
                                @invoice.Order?.Vehicle?.Client?.FullName
                            </td>
                            <td>
                                @invoice.Order?.Vehicle?.Brand
                                @invoice.Order?.Vehicle?.Model
                            </td>
                            <td>@invoice.NetAmount.ToString("C")</td>
                            <td>@invoice.VatAmount.ToString("C")</td>
                            <td>
                                <strong>
                                    @invoice.GrossAmount.ToString("C")
                                </strong>
                            </td>
                            <td>
                                <a asp-action="GenerateInvoice"
                                   asp-route-id="@invoice.OrderId"
                                   class="btn-action" title="Pobierz PDF"
                                   target="_blank">
                                    📄
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}