@using WarsztatTuningowy.Extensions
@using WarsztatTuningowy.Models.Enums
@model WarsztatTuningowy.Models.Domain.Order
@{
    ViewData["Title"] = $"Zlecenie #{Model.Id} — widok roboczy";
    var activeAssignment = Model.WorkstationAssignments
        .FirstOrDefault(wa => wa.IsActive);
    var badgeClass = Model.Status switch
    {
        OrderStatus.Received => "bg-secondary",
        OrderStatus.Diagnosis => "bg-info",
        OrderStatus.InProgress => "bg-warning text-dark",
        OrderStatus.QualityCheck => "bg-primary",
        OrderStatus.Completed => "bg-success",
        _ => "bg-secondary"
    };
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">
                Moje zlecenia
            </a>
        </li>
        <li class="breadcrumb-item active">
            Zlecenie #@Model.Id
        </li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="mb-1">
            Zlecenie #@Model.Id
            <span class="badge @badgeClass ms-2 fs-6">
                @Model.Status.GetDisplayName()
            </span>
        </h1>
        <small class="text-muted">
            @Model.Vehicle?.Brand @Model.Vehicle?.Model
            (@Model.Vehicle?.Year) ·
            @Model.Vehicle?.Client?.FullName
        </small>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">

        <div class="card mb-4">
            <div class="card-header fw-bold">Dane pojazdu</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">VIN</dt>
                    <dd class="col-sm-8">
                        <code>@Model.Vehicle?.VIN</code>
                    </dd>
                    <dt class="col-sm-4 text-muted">Silnik</dt>
                    <dd class="col-sm-8">@Model.Vehicle?.EngineType</dd>
                    <dt class="col-sm-4 text-muted">ECU</dt>
                    <dd class="col-sm-8">@Model.Vehicle?.ECUType</dd>
                    <dt class="col-sm-4 text-muted">Cel tuningu</dt>
                    <dd class="col-sm-8">
                        @Model.TuningGoal.GetDisplayName()
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-bold">Zadania serwisowe</div>
            <div class="card-body p-0">
                @if (!Model.ServiceTasks.Any())
                {
                    <p class="text-muted p-3 mb-0">
                        Brak zadań dla tego zlecenia
                    </p>
                }
                else
                {
                    @foreach (var task in Model.ServiceTasks)
                    {
                        var timerClass = task.EndTime != null
                            ? "border-success"
                            : task.StartTime != null
                                ? "border-warning"
                                : "border-secondary";

                        <div class="p-3 border-bottom border-2
                            border-start @timerClass">
                            <div class="d-flex justify-content-between
                                align-items-start mb-2">
                                <div>
                                    <div class="fw-semibold">
                                        @task.Name
                                    </div>
                                    <small class="text-muted">
                                        @(task.AssignedEmployee?.FullName?? "Brak mechanika")
                                        · Czas: @task.TotalTime
                                    </small>
                                </div>
                                @if (task.EndTime != null)
                                {
                                    <span class="badge bg-success">
                                        Zakończone
                                    </span>
                                }
                                else if (task.StartTime != null)
                                {
                                    <span class="badge bg-warning text-dark">
                                        ⏱ W trakcie
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Nie rozpoczęto
                                    </span>
                                }
                            </div>

                            <div class="d-flex gap-2 flex-wrap mb-2">
                                @if (task.StartTime == null)
                                {
                                    <form asp-controller="ServiceTasks" asp-action="Start" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <input type="hidden" name="returnView" value="WorkView" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            ▶ START
                                        </button>
                                    </form>
                                }
                                else if (task.EndTime == null)
                                {
                                    <form asp-controller="ServiceTasks" asp-action="Stop" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <input type="hidden" name="returnView" value="WorkView" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            ■ STOP
                                        </button>
                                    </form>

                                    <form asp-controller="ServiceTasks" asp-action="Pause"
                                          method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <input type="hidden" name="returnView" value="WorkView" />
                                        <input type="number" name="pauseMinutes"
                                               class="form-control form-control-sm"
                                               style="width:80px" placeholder="min" min="1" />
                                        <button type="submit" class="btn btn-sm btn-warning">
                                            ⏸ PAUZA
                                        </button>
                                    </form>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(task.Notes))
                            {
                                <div class="bg-light rounded p-2 mb-2"
                                     style="font-size:.85rem; white-space:pre-line">
                                    @task.Notes
                                </div>
                            }

                            <form asp-controller="ServiceTasks" asp-action="AddNotes"
                                  method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@task.Id" />
                                <input type="text" name="notes" class="form-control form-control-sm"
                                       placeholder="Dodaj notatkę techniczną..." required />
                                <button type="submit" class="btn btn-sm btn-outline-secondary
                                    text-nowrap">
                                    + Notatka
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-bold">Części zlecenia</div>
            <div class="card-body p-0">
                @if (!Model.OrderParts.Any())
                {
                    <p class="text-muted p-3 mb-0">
                        Brak przypisanych części
                    </p>
                }
                else
                {
                    <table class="table table-modern mb-0">
                        <thead>
                            <tr>
                                <th>Część</th>
                                <th>Ilość</th>
                                <th>VIN-lock</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var op in Model.OrderParts)
                            {
                                <tr class="@(op.IsUsed ? "table-success" : "")">
                                    <td>
                                        <div class="fw-semibold">
                                            @op.Part?.Name
                                        </div>
                                        <small class="text-muted">
                                            @op.Part?.SupplierName
                                        </small>
                                    </td>
                                    <td>@op.Quantity szt.</td>
                                    <td>
                                        @if (op.IsVinLocked)
                                        {
                                            <code style="font-size:.75rem">
                                                @op.LockedVin
                                            </code>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (op.IsUsed)
                                        {
                                            <span class="badge bg-success">
                                                Użyta ✓
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                Nie użyta
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (!op.IsUsed)
                                        {
                                            <form asp-action="MarkPartUsed"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="orderId"
                                                       value="@Model.Id" />
                                                <input type="hidden" name="partId"
                                                       value="@op.PartId" />
                                                <input type="hidden" name="returnToWorkView"
                                                       value="true" />
                                                <button type="submit" class="btn btn-sm
                                                    btn-outline-success">
                                                    ✓ Oznacz jako użytą
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header fw-bold">Stanowisko robocze</div>
            <div class="card-body">
                @if (activeAssignment != null)
                {
                    <div class="alert alert-warning mb-3">
                        <div class="fw-semibold">
                            @activeAssignment.Workstation?.Name
                        </div>
                        <small class="text-muted">
                            @activeAssignment.Workstation?.Type.GetDisplayName() ·
                            od @activeAssignment.AssignedAt.ToString("dd.MM HH:mm")
                        </small>
                    </div>

                    <form asp-controller="Workstations" asp-action="Release" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@activeAssignment.WorkstationId" />
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                            Zwolnij stanowisko
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-3">
                        Brak przypisanego stanowiska
                    </p>
                }

                @{
                    var freeWorkstations = ViewBag.FreeWorkstations
                        as List<WarsztatTuningowy.Models.Domain.Workstation>;
                }
                @if (freeWorkstations != null && freeWorkstations.Any())
                {
                    <form asp-controller="Workstations" asp-action="Assign" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <div class="d-flex gap-2 mt-2">
                            <select name="workstationId" class="form-select form-select-sm">
                                @foreach (var ws in freeWorkstations)
                                {
                                    <option value="@ws.Id">
                                        @ws.Name
                                        (@ws.Type.GetDisplayName())
                                    </option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-success text-nowrap">
                                Przypisz
                            </button>
                        </div>
                    </form>
                }
                else if (activeAssignment == null)
                {
                    <small class="text-muted">
                        Brak wolnych stanowisk
                    </small>
                }
            </div>
        </div>

        @if (Model.Status == OrderStatus.InProgress)
        {
            <div class="card mb-4">
                <div class="card-header fw-bold">Zmiana statusu</div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Gdy praca zakończona — przenieś do kontroli jakości.
                    </p>
                    <form asp-controller="Orders" asp-action="ChangeStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="newStatus"
                               value="@OrderStatus.QualityCheck" />
                        <button type="submit" class="btn btn-primary w-100">
                            → Przekaż do kontroli jakości
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header fw-bold">Informacje</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-6 text-muted">Szac. czas</dt>
                    <dd class="col-sm-6">@Model.EstimatedHours h</dd>
                    <dt class="col-sm-6 text-muted">Zaliczka</dt>
                    <dd class="col-sm-6">
                        @if (Model.DepositPaid)
                        {
                            <span class="badge bg-success">Wpłacona</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Brak</span>
                        }
                    </dd>
                    <dt class="col-sm-6 text-muted">Utworzone</dt>
                    <dd class="col-sm-6">
                        @Model.CreatedAt.ToString("dd.MM.yyyy")
                    </dd>
                </dl>
            </div>
        </div>

    </div>
</div>