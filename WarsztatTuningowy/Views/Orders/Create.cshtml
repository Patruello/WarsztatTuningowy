@using WarsztatTuningowy.Extensions
@using WarsztatTuningowy.Models.Enums
@model WarsztatTuningowy.Models.Domain.Order
@{
    ViewData["Title"] = "Nowe zlecenie";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Zlecenia</a>
        </li>
        <li class="breadcrumb-item active">Nowe zlecenie</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
          color:var(--gray-500);text-transform:uppercase; margin-bottom:.5rem">
        Nowy rekord
    </div>
    <h1>Nowe zlecenie</h1>
    <p class="page-subtitle">Utwórz nowe zlecenie tuningowe.</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header fw-bold">Dane zlecenia</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="VehicleId" class="form-label">
                            Pojazd <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-2">
                            <select asp-for="VehicleId" class="form-select" asp-items="ViewBag.VehicleId">
                                <option value="">— wybierz pojazd —</option>
                            </select>
                        </div>
                        <div class="form-text d-flex gap-3 mt-1">
                            <a asp-controller="Vehicles" asp-action="Create"
                                  asp-route-returnUrl="/Orders/Create" class="btn btn-outline-secondary text-nowrap">
                                + Dodaj nowy pojazd
                            </a>
                            <a asp-controller="Clients" asp-action="Create" 
                                  asp-route-returnUrl="/Orders/Create" class="btn btn-outline-secondary text-nowrap">
                                + Dodaj nowego klienta (z pojazdem)
                            </a>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Cel tuningu <span class="text-danger">*</span>
                        </label>
                        <div class="card p-3 mb-2">
                            <div class="text-muted small mb-2">
                                Stopień chiptuningu (wybierz jeden)
                            </div>
                            @foreach (var stage in new[] {
                                (1, "Stage 1"), (2, "Stage 2"), (4, "Stage 3")
                            })
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"name="tuningGoals"
                                          value="@stage.Item1" id="stage@stage.Item1" />
                                    <label class="form-check-label" for="stage@stage.Item1">
                                        @stage.Item2
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="card p-3">
                            <div class="text-muted small mb-2">
                                Dodatki (można łączyć)
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="tuningGoals"
                                      value="8" id="mechanical" />
                                <label class="form-check-label" for="mechanical">
                                    Modyfikacje mechaniczne
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="tuningGoals" value="16"
                                       id="visual" />
                                <label class="form-check-label" for="visual">
                                    Modyfikacje wizualne
                                </label>
                            </div>
                        </div>
                        <span class="text-danger small" id="tuningGoalError"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EstimatedHours" class="form-label" placeholder="np. 8 lub 8,5">
                            Szacowany czas (h)
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="EstimatedHours" class="form-control" placeholder="np. 8" />
                        <span asp-validation-for="EstimatedHours" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultMechanicId" class="form-label">
                            Domyślny mechanik
                        </label>
                        <select asp-for="DefaultMechanicId" class="form-select"
                                asp-items="ViewBag.DefaultMechanicId">
                            <option value="">— wybierz mechanika —</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox"
                                   asp-for="DepositPaid" role="switch" />
                            <label class="form-check-label" asp-for="DepositPaid">
                                Zaliczka wpłacona
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Anuluj
                        </a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Utwórz zlecenie
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}