@using WarsztatTuningowy.Extensions
@model WarsztatTuningowy.Models.Domain.Order
@{
    ViewData["Title"] = "Oświadczenie klienta";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Zlecenia</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Details" asp-route-id="@Model.Id">
                Zlecenie #@Model.Id
            </a>
        </li>
        <li class="breadcrumb-item active">Oświadczenie klienta</li>
    </ol>
</nav>

<div class="page-header">
    <h1>Oświadczenie klienta</h1>
    <p class="page-subtitle">
        Zlecenie #@Model.Id —
        @Model.Vehicle?.Brand @Model.Vehicle?.Model ·
        @Model.Vehicle?.Client?.FullName
    </p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        @TempData["Error"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.HasElectronicStatement)
{
    <div class="alert alert-success mb-4">
        <div class="fw-semibold">
            ✓ Oświadczenie zaakceptowane elektronicznie
        </div>
        <div class="small mt-1">
            Przez: <strong>@Model.StatementAcceptedBy</strong> ·
            Dnia: <strong>
            @Model.StatementAcceptedAt?.ToString("dd.MM.yyyy HH:mm")
        </strong>
    </div>
</div>

<a asp-action="GenerateStatement" asp-route-id="@Model.Id"
   class="btn btn-outline-primary" target="_blank">
    📄 Pobierz PDF oświadczenia
</a>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header fw-bold">
                    Treść oświadczenia
                </div>
                <div class="card-body p-4">

                    <div class="p-3 mb-4 rounded" style="background:var(--gray-50);
                         border:1px solid var(--gray-200)">
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <small class="text-muted">Klient</small>
                                <div class="fw-semibold">
                                    @Model.Vehicle?.Client?.FullName
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted">Pojazd</small>
                                <div class="fw-semibold">
                                    @Model.Vehicle?.Brand
                                    @Model.Vehicle?.Model
                                    (@Model.Vehicle?.Year)
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted">VIN</small>
                                <div><code>@Model.Vehicle?.VIN</code></div>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted">Cel tuningu</small>
                                <div>@Model.TuningGoal.GetDisplayName()</div>
                            </div>
                        </div>
                    </div>

                    <p class="text-muted fst-italic mb-4">
                        Ja, niżej podpisany/a, oświadczam że zostałem/am poinformowany/a o zakresie oraz konsekwencjach
                        technicznych i prawnych zleconych modyfikacji pojazdu.
                    </p>

                    <form asp-action="Statement" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-4">
                            <div class="form-check mb-3">
                                <input class="form-check-input"
                                       type="checkbox"  name="modificationScopeAccepted"
                                       value="true" id="check1" required />
                                <label class="form-check-label" for="check1">
                                    Akceptuję zakres modyfikacji pojazdu określony w zleceniu nr
                                    <strong>#@Model.Id</strong>
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="legalConsequencesAccepted"
                                       value="true" id="check2" required />
                                <label class="form-check-label" for="check2">
                                    Rozumiem możliwy wpływ modyfikacji na emisję spalin oraz systemy
                                    DPF/OPF/GPF i akceptuję konsekwencje prawne (badanie techniczne, ubezpieczenie)
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" name="warrantyLossAccepted"
                                       value="true" id="check3" required />
                                <label class="form-check-label" for="check3">
                                    Akceptuję ryzyko utraty gwarancji producenta pojazdu w wyniku przeprowadzonych modyfikacji
                                </label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                Imię i nazwisko osoby akceptującej
                                <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="statementAcceptedBy"  class="form-control"
                                   placeholder="np. Jan Kowalski"
                                   value="@Model.Vehicle?.Client?.FullName" required />
                            <div class="form-text">
                                Domyślnie imię i nazwisko klienta.
                            </div>
                        </div>

                        <div class="alert alert-warning mb-4">
                            ⚠️ Po zatwierdzeniu oświadczenie zostanie zapisane elektronicznie z datą i godziną akceptacji. 
                            Operacja jest nieodwracalna.
                        </div>

                        <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                            <a asp-action="Details"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-secondary">
                                Anuluj
                            </a>
                            <button type="submit" class="btn btn-primary">
                                ✓ Zatwierdź oświadczenie elektronicznie
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-warning">
                <div class="card-header fw-bold text-warning">
                    ⚠️ Informacja prawna
                </div>
                <div class="card-body small">
                    <p>
                        Elektroniczna akceptacja oświadczenia jest równoznaczna z pisemnym potwierdzeniem zgody klienta na wykonanie modyfikacji.
                    </p>
                    <p>
                        System zapisuje datę, godzinę oraz imię i nazwisko osoby akceptującej jako dowód wyrażenia zgody.
                    </p>
                    <p class="mb-0">
                        Po akceptacji można pobrać PDF jako potwierdzenie dla klienta.
                    </p>
                </div>
            </div>
        </div>
    </div>
}