@using WarsztatTuningowy.Extensions
@using WarsztatTuningowy.Models.Enums
@model IEnumerable<WarsztatTuningowy.Models.Domain.Order>
@{
    ViewData["Title"] = "Moje zlecenia";
    var employee = ViewBag.Employee as WarsztatTuningowy.Models.Domain.Employee;
}

<div class="page-header">
    <h1>Moje zlecenia</h1>
    <p class="page-subtitle">
        Witaj, <strong>@employee?.FullName</strong>!
        Masz <strong>@Model.Count()</strong> aktywnych zleceń.
    </p>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-label">Aktywne zlecenia</div>
            <div class="stat-value text-warning">@Model.Count()</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-label">Timer aktywny</div>
            <div class="stat-value text-danger">
                @Model.Count(o => o.ServiceTasks.Any(
                    st => st.StartTime != null && st.EndTime == null))
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-label">Stawka klienta</div>
            <div class="stat-value text-success">
                @employee?.HourlyRateClient zł/h
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-bold">Moje aktywne zlecenia</div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <p class="text-muted p-4 mb-0">
                Nie masz przypisanych aktywnych zleceń 🎉
            </p>
        }
        else
        {
            <table class="table table-modern w-100">
                <thead>
                    <tr>
                        <th>Nr</th>
                        <th>Pojazd</th>
                        <th>Cel tuningu</th>
                        <th>Status</th>
                        <th>Zadania</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        var badgeClass = order.Status switch
                        {
                            OrderStatus.Received => "bg-secondary",
                            OrderStatus.Diagnosis => "bg-info",
                            OrderStatus.InProgress => "bg-warning text-dark",
                            OrderStatus.QualityCheck => "bg-primary",
                            _ => "bg-secondary"
                        };

                        var activeTask = order.ServiceTasks
                            .FirstOrDefault(st =>
                                st.StartTime != null && st.EndTime == null);

                        <tr class="@(activeTask != null ? "table-warning" : "")">
                            <td><strong>#@order.Id</strong></td>
                            <td>
                                <div class="fw-semibold">
                                    @order.Vehicle?.Brand @order.Vehicle?.Model
                                </div>
                                <small class="text-muted">
                                    @order.Vehicle?.Year ·
                                    @order.Vehicle?.EngineType
                                </small>
                            </td>
                            <td>
                                <small>
                                    @order.TuningGoal.GetDisplayName()
                                </small>
                            </td>
                            @{
                                var hasAnyParts = order.OrderParts.Any()
                                    || order.PartRequests.Any();
                            }
                            <td>
                                <span class="badge @badgeClass">
                                    @order.Status.GetDisplayName()
                                </span>

                                @if (hasAnyParts && !order.IsReadyForTuning())
                                {
                                    <span class="badge bg-warning text-dark mt-1">
                                        ⏳ Oczekuje na części
                                    </span>
                                }
                                else if (order.IsReadyForTuning())
                                {
                                    <span class="badge bg-success mt-1">
                                        ✓ Gotowy do tuningu
                                    </span>
                                }
                            </td>
                            <td>
                                @if (activeTask != null)
                                {
                                    <span class="badge bg-warning text-dark">
                                        ⏱ @activeTask.Name
                                    </span>
                                }
                                else
                                {
                                    <small class="text-muted">
                                        @order.ServiceTasks.Count(st =>
                                            st.EndTime != null) /
                                        @order.ServiceTasks.Count zadań
                                    </small>
                                }
                            </td>
                            <td>
                                <a asp-controller="Orders" asp-action="WorkView" asp-route-id="@order.Id"
                                   class="btn-action" title="Otwórz">👁</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>