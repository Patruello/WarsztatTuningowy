@using WarsztatTuningowy.Extensions
@model WarsztatTuningowy.Models.Domain.Workstation
@{
    ViewData["Title"] = "Edytuj stanowisko";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Stanowiska</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Details" asp-route-id="@Model.Id">@Model.Name</a>
        </li>
        <li class="breadcrumb-item active">Edycja</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
        color:var(--gray-500);text-transform:uppercase;
        margin-bottom:.5rem">
        Edycja rekordu
    </div>
    <h1>Edytuj stanowisko</h1>
    <p class="page-subtitle">
        Zmieniasz dane <strong>@Model.Name</strong>.
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header fw-bold">Dane stanowiska</div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nazwa</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label">
                            Typ stanowiska
                        </label>
                        <select asp-for="Type" class="form-select"
                                asp-items="ViewBag.Type">
                        </select>
                        <span asp-validation-for="Type"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Status</label>
                        <div class="form-control-plaintext">
                            @if (Model.IsOccupied)
                            {
                                <span class="badge bg-danger">ZAJĘTE</span>
                                <small class="text-muted ms-2">
                                    Status zmienia się automatycznie
                                    przy przypisaniu zlecenia
                                </small>
                            }
                            else
                            {
                                <span class="badge bg-success">WOLNE</span>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end
                        pt-3 border-top">
                        <a asp-action="Details" asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Zapisz zmiany
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}