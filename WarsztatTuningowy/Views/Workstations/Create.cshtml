@using WarsztatTuningowy.Extensions
@model WarsztatTuningowy.Models.Domain.Workstation
@{
    ViewData["Title"] = "Nowe stanowisko";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Stanowiska</a>
        </li>
        <li class="breadcrumb-item active">Nowe stanowisko</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
        color:var(--gray-500);text-transform:uppercase;
        margin-bottom:.5rem">
        Nowy rekord
    </div>
    <h1>Dodaj stanowisko</h1>
    <p class="page-subtitle">
        Nowe stanowisko będzie dostępne do przypisania przy zleceniach.
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header fw-bold">Dane stanowiska</div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            Nazwa <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="np. Podnośnik 2" />
                        <span asp-validation-for="Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Type" class="form-label">
                            Typ stanowiska <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Type" class="form-select" asp-items="ViewBag.Type">
                            <option value="">— wybierz typ —</option>
                        </select>
                        <span asp-validation-for="Type"
                              class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Anuluj
                        </a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Dodaj stanowisko
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}