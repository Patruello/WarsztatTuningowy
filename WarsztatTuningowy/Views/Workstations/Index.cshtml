@using WarsztatTuningowy.Extensions
@model IEnumerable<WarsztatTuningowy.Models.Domain.Workstation>
@{
    ViewData["Title"] = "Stanowiska";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Stanowiska</li>
    </ol>
</nav>

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Stanowiska robocze</h1>
        <p class="page-subtitle">
            @Model.Count(w => w.IsOccupied) zajętych ·
            @Model.Count(w => !w.IsOccupied) wolnych
        </p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Dodaj stanowisko</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    @foreach (var item in Model)
    {
        var activeAssignment = item.Assignments.FirstOrDefault(a => a.IsActive);

        <div class="col">
            <div class="card h-100 border-2
                @(item.IsOccupied ? "border-danger" : "border-success")">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <span class="fw-bold">@item.Name</span>
                        <small class="text-muted d-block">
                            @item.Type.GetDisplayName()
                        </small>
                    </div>
                    @if (item.IsOccupied)
                    {
                        <span class="badge bg-danger">ZAJĘTE</span>
                    }
                    else
                    {
                        <span class="badge bg-success">WOLNE</span>
                    }
                </div>
                <div class="card-body">
                    @if (activeAssignment != null)
                    {
                        <div class="alert alert-warning py-2 mb-0">
                            <small class="d-block text-muted">
                                Aktualne zlecenie:
                            </small>
                            <strong>
                                @activeAssignment.Order?.Vehicle?.Brand
                                @activeAssignment.Order?.Vehicle?.Model
                            </strong>
                            <small class="d-block text-muted">
                                od @activeAssignment.AssignedAt.ToString("dd.MM HH:mm")
                            </small>
                            <a asp-controller="Orders" asp-action="Details"
                               asp-route-id="@activeAssignment.OrderId"
                               class="btn btn-sm btn-outline-warning mt-2">
                                Zobacz zlecenie
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">
                            Stanowisko jest wolne
                        </p>
                    }
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-secondary">
                        Szczegóły
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-primary">
                        Edytuj
                    </a>
                </div>
            </div>
        </div>
    }
</div>