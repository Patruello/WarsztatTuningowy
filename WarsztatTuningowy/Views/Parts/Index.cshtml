@model IEnumerable<WarsztatTuningowy.Models.Domain.Part>
@{
    ViewData["Title"] = "Magazyn części";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Magazyn części</li>
    </ol>
</nav>

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Magazyn części</h1>
        <p class="page-subtitle">@Model.Count() części w magazynie</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Dodaj część</a>
</div>

@if (Model.Any(p => p.IsLowStock()))
{
    <div class="alert alert-warning d-flex align-items-center mb-4">
        <span class="me-2">⚠️</span>
        <div>
            <strong>Niski stan magazynu!</strong>
            @Model.Count(p => p.IsLowStock()) części poniżej stanu minimalnego.
        </div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-label">Wszystkie części</div>
            <div class="stat-value">@Model.Count()</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-label">Niski stan</div>
            <div class="stat-value text-danger">
                @Model.Count(p => p.IsLowStock())
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-label">Śr. marża</div>
            <div class="stat-value text-success">
                @(Model.Any()
                    ? Model.Average(p => (double)p.Margin()).ToString("C")
                    : "—")
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-label">Wartość magazynu</div>
            <div class="stat-value text-primary">
                @Model.Sum(p => p.WholesalePrice * p.Stock).ToString("C")
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-modern w-100">
            <thead>
                <tr>
                    <th>Nazwa części</th>
                    <th>Cena hurt.</th>
                    <th>Cena detal.</th>
                    <th>Marża</th>
                    <th>Typ cześci</th>
                    <th>Stan</th>
                    <th>Min. stan</th>
                    <th>Dostawca</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsLowStock() ? "table-danger" : "")">
                        <td>
                            <strong>@item.Name</strong>
                            @if (item.IsLowStock())
                            {
                                <span class="badge bg-danger ms-2">
                                    Niski stan
                                </span>
                            }
                        </td>
                        <td>@item.WholesalePrice.ToString("C")</td>
                        <td>@item.RetailPrice.ToString("C")</td>
                        <td>
                            <span class="@(item.Margin() > 0 ? "text-success fw-bold" : "text-danger")">
                                @item.Margin().ToString("C")
                            </span>
                        </td>
                        <td>
                            @if (item.IsStockPart)
                            {
                                <span class="badge bg-primary">Magazynowa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Na zamówienie</span>
                            }
                        </td>
                        <td>
                            <span class="@(item.IsLowStock() ? "fw-bold text-danger" : "")">
                                @item.Stock szt.
                            </span>
                            @if (item.ReservedQuantity > 0)
                            {
                                <small class="text-muted d-block">
                                    @item.ReservedQuantity zarezerwowane
                                </small>
                            }
                        </td>
                        <td>@item.MinStock szt.</td>
                        <td>
                            <small class="text-muted">@item.SupplierName</small>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn-action" title="Szczegóły">👁</a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn-action" title="Edytuj">✏️</a>
                                <a asp-action="StockAdjustment"
                                   asp-route-id="@item.Id"
                                   class="btn-action" title="Korekta stanu">📦</a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn-action btn-action-danger"
                                   title="Usuń">🗑</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>