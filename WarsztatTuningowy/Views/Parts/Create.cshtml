@model WarsztatTuningowy.Models.Domain.Part
@{
    ViewData["Title"] = "Nowa część";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Magazyn części</a>
        </li>
        <li class="breadcrumb-item active">Nowa część</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
          color:var(--gray-500);text-transform:uppercase; margin-bottom:.5rem">
        Nowy rekord
    </div>
    <h1>Dodaj część</h1>
    <p class="page-subtitle">Dodaj nową część do magazynu.</p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header fw-bold">Dane części</div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly"
                          class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            Nazwa <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="np. Intercooler Wagner Tuning" />
                        <span asp-validation-for="Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="WholesalePrice" class="form-label">
                                Cena hurtowa (zł)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="WholesalePrice" class="form-control"
                                   placeholder="np. 1800" />
                            <span asp-validation-for="WholesalePrice"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RetailPrice" class="form-label">
                                Cena detaliczna (zł)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="RetailPrice" class="form-control"
                                   placeholder="np. 2400" />
                            <span asp-validation-for="RetailPrice"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label">
                                Stan początkowy (szt.)
                            </label>
                            <input asp-for="Stock" class="form-control"
                                   placeholder="0" />
                            <span asp-validation-for="Stock"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MinStock" class="form-label">
                                Stan minimalny (szt.)
                            </label>
                            <input asp-for="MinStock" class="form-control"
                                   placeholder="1" />
                            <span asp-validation-for="MinStock"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="SupplierName" class="form-label">
                            Dostawca
                        </label>
                        <input asp-for="SupplierName" class="form-control"
                               placeholder="np. Wagner Tuning PL" />
                        <span asp-validation-for="SupplierName"
                              class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end
                        pt-3 border-top">
                        <a asp-action="Index"
                           class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Dodaj część
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}