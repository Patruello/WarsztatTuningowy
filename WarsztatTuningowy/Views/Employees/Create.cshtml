@using WarsztatTuningowy.Models.Enums
@using WarsztatTuningowy.Extensions
@model WarsztatTuningowy.Models.Domain.Employee

@{
    ViewData["Title"] = "Nowy Pracownik";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Pracownicy</a>
        </li>
        <li class="breadcrumb-item active">Nowy pracownik</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
        color:var(--gray-500);text-transform:uppercase;
        margin-bottom:.5rem">
        Nowy rekord
    </div>
    <h1>Dodaj pracownika</h1>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header fw-bold">Dane pracownika</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">
                            Imię i nazwisko
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FullName" class="form-control"
                               placeholder="np. Jan Kowalski" />
                        <span asp-validation-for="FullName"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">
                            Rola <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Role" class="form-select" asp-items="ViewBag.Role">
                            <option value="">— wybierz rolę —</option>
                        </select>
                        <span asp-validation-for="Role"
                              class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="HourlyRateInternal"
                                   class="form-label">
                                Stawka wewnętrzna (zł/h)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="HourlyRateInternal"
                                   class="form-control" placeholder="np. 60" />
                            <span asp-validation-for="HourlyRateInternal"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HourlyRateClient"
                                   class="form-label">
                                Stawka klienta (zł/h)
                                <span class="text-danger">*</span>
                            </label>
                            <input asp-for="HourlyRateClient"
                                   class="form-control" placeholder="np. 250" />
                            <span asp-validation-for="HourlyRateClient"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UserId" class="form-label">
                            Konto systemowe
                        </label>
                        <select asp-for="UserId" class="form-select"
                                asp-items="ViewBag.UserId">
                            <option value="">— bez konta —</option>
                        </select>
                        <div class="form-text">
                            Przypisz konto Identity żeby pracownik
                            mógł się logować.
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end
                        pt-3 border-top">
                        <a asp-action="Index"
                           class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Dodaj pracownika
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
