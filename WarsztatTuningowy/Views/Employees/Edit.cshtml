@model WarsztatTuningowy.Models.Domain.Employee

@{
    ViewData["Title"] = "Edytuj pracownika";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Index">Pracownicy</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Details" asp-route-id="@Model.Id">
                @Model.FullName
            </a>
        </li>
        <li class="breadcrumb-item active">Edycja</li>
    </ol>
</nav>

<div class="page-header">
    <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;
        color:var(--gray-500);text-transform:uppercase;
        margin-bottom:.5rem">
        Edycja rekordu
    </div>
    <h1>Edytuj pracownika</h1>
    <p class="page-subtitle">
        Zmieniasz dane <strong>@Model.FullName</strong>.
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header fw-bold">Dane pracownika</div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">
                            Imię i nazwisko
                        </label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName"
                              class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Rola</label>
                        <select asp-for="Role" class="form-select"
                                asp-items="ViewBag.Role">
                        </select>
                        <span asp-validation-for="Role"
                              class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="HourlyRateInternal"
                                   class="form-label">
                                Stawka wewnętrzna (zł/h)
                            </label>
                            <input asp-for="HourlyRateInternal"
                                   class="form-control" />
                            <span asp-validation-for="HourlyRateInternal"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HourlyRateClient"
                                   class="form-label">
                                Stawka klienta (zł/h)
                            </label>
                            <input asp-for="HourlyRateClient"
                                   class="form-control" />
                            <span asp-validation-for="HourlyRateClient"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UserId" class="form-label">
                            Konto systemowe
                        </label>
                        <select asp-for="UserId" class="form-select"
                                asp-items="ViewBag.UserId">
                            <option value="">— bez konta —</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2 justify-content-end
                        pt-3 border-top">
                        <a asp-action="Details" asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">
                            ✓ Zapisz zmiany
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
